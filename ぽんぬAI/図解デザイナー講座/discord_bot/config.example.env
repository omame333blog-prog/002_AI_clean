# Discord Bot 設定
# このファイルを config.env にコピーして、値を記入してください

# Botトークン（Developer Portal > Bot > Reset Token で取得）
DISCORD_BOT_TOKEN=your_bot_token_here

# チェック対象のチャンネルID（カンマ区切り、複数可）
# 例：ブラウン部屋,ブルー部屋,レッド部屋
CHANNEL_IDS=1234567890123456789,2345678901234567890

# 日報担当のDiscord Username（返信チェック用、カンマ区切り）
# 全チャンネル共通の場合はこちら
NIKKI_TANTO_USERNAMES=ikumi_san,another_tanto

# チャンネルごとの日報担当（オプション）形式: チャンネルID:Username
# 例：1234567890123456789:ikumi_san,2345678901234567890:tanaka_san
# 設定すると NIKKI_TANTO_USERNAMES より優先
# CHANNEL_TANTO_MAP=
